---
import MainLayout from '../layouts/MainLayout.astro';
import { MotionFadeIn, MotionStagger, MotionStaggerItem } from '../components/MotionFadeIn.tsx';
---

<MainLayout title="Arquitectura y Modelización | U-Locate">
  <article class="section-container prose-google max-w-5xl">
    <MotionFadeIn client:load direction="down" className="mb-12 md:mb-20 text-center md:text-left">
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-[#fce8e6] rounded-full mb-6 text-[#ea4335]">
        <span class="w-1.5 h-1.5 bg-[#ea4335] rounded-full animate-bounce"></span>
        <span class="text-[10px] font-black uppercase tracking-widest">Fase 2: Arquitectura del Sistema</span>
      </div>
      <h1 class="text-4xl md:text-6xl font-black text-[#202124] tracking-tight mb-8 leading-tight">
        Modelando el Blueprint Técnico
      </h1>
      <p class="text-lg md:text-xl text-[#5f6368] font-light leading-relaxed max-w-3xl">
        Transformamos los requerimientos en estructuras visuales. El modelado estructurado que garantiza que cada dato e interacción tenga un lugar lógico.
      </p>
    </MotionFadeIn>

    <div class="space-y-32">
      <!-- A. Modelado de Datos -->
      <section>
        <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-8">
           <div class="flex items-center gap-6">
             <div class="w-16 h-16 bg-[#e8f0fe] rounded-2xl md:rounded-3xl flex items-center justify-center text-[#1a73e8] font-black text-2xl shadow-xl shadow-blue-100 rotate-6">A</div>
             <div>
               <h2 class="text-2xl md:text-3xl font-black text-[#202124] m-0">Modelado de Datos</h2>
               <p class="text-sm text-[#5f6368] mt-1 font-medium">Estructura lógicamente optimizada (DER)</p>
             </div>
           </div>
           <div class="bg-blue-50 px-4 py-2 rounded-xl text-[10px] font-black text-blue-600 uppercase border border-blue-100 tracking-tighter hidden sm:block">Normalización 3ra Forma Normal</div>
        </div>
        
        <div class="prose-google max-w-none text-[#5f6368] mb-12">
          <p class="text-base md:text-lg font-light leading-relaxed mb-8">
            El **Diagrama Entidad-Relación (DER)** es la columna vertebral de nuestra base de datos. No solo almacena nombres, sino que establece la jerarquía espacial necesaria para la navegación inteligente dentro del campus.
          </p>
          <div class="grid md:grid-cols-2 gap-6 md:gap-8 bg-[#f8f9fa] p-6 md:p-10 rounded-2xl md:rounded-3xl border border-[#dadce0] mb-12">
            <div class="space-y-4">
              <h4 class="text-[#202124] font-bold flex items-center gap-2 text-sm md:text-base">
                <span class="w-2 h-2 bg-[#1a73e8] rounded-full"></span>
                Entidades Clave
              </h4>
              <ul class="text-[13px] md:text-sm space-y-3">
                <li class="pl-4 border-l-2 border-blue-100"><strong>Edificio:</strong> Almacena coordenadas centrales e información administrativa del bloque.</li>
                <li class="pl-4 border-l-2 border-blue-100"><strong>Espacio:</strong> Define cada aula, laboratorio u oficina con precisión geométrica.</li>
                <li class="pl-4 border-l-2 border-blue-100"><strong>Categoría:</strong> Motor de clasificación para filtros dinámicos (ej. "Cafetines").</li>
              </ul>
            </div>
            <div class="space-y-4">
              <h4 class="text-[#202124] font-bold flex items-center gap-2 text-sm md:text-base">
                <span class="w-2 h-2 bg-[#1a73e8] rounded-full"></span>
                Relación Jerárquica (1:N)
              </h4>
              <p class="text-[13px] md:text-sm leading-relaxed">
                Implementamos una relación de uno a muchos entre Edificios y Espacios. Esta estructura garantiza que cada punto de interés esté anclado a un bloque físico, permitiendo que el sistema calcule rutas de "Entrada" y "Salida" con total integridad referencial.
              </p>
            </div>
          </div>
        </div>

        <!-- Image Container -->
        <div class="bg-[#f8f9fa] p-1 md:p-2 rounded-[2rem] md:rounded-[3.5rem] border border-[#dadce0] relative group">
          <div class="bg-white border border-[#dadce0] rounded-[1.8rem] md:rounded-[3rem] p-6 md:p-12 overflow-hidden flex flex-col items-center shadow-inner hover:shadow-2xl transition-all duration-500">
            <h4 class="text-[9px] md:text-[10px] font-black uppercase tracking-widest text-[#5f6368] mb-6 md:mb-10 text-center flex items-center gap-3 md:gap-4 opacity-40">
              <span class="w-8 md:w-12 h-px bg-[#dadce0]"></span>
              Diagrama Entidad-Relación de U-Locate
              <span class="w-8 md:w-12 h-px bg-[#dadce0]"></span>
            </h4>
            
            <div class="relative w-full max-w-4xl group-hover:scale-[1.01] transition-transform duration-700">
              <div class="absolute inset-0 bg-[#4285f4] opacity-0 group-hover:opacity-5 blur-3xl transition-all"></div>
              <img
                src="/DER.png"
                alt="Diagrama Entidad-Relación de U-Locate"
                class="w-full h-auto opacity-95 transition-opacity"
              />
            </div>
            
            <p class="mt-8 md:mt-12 text-[10px] md:text-xs text-[#5f6368] italic font-medium px-4 text-center max-w-lg border-t border-slate-100 pt-6 md:pt-8 leading-relaxed">
              "El modelo ha sido optimizado en su 3ra Forma Normal, eliminando redundancias y preparando la base para futuros servicios de geofencing."
            </p>
          </div>
        </div>
      </section>

      <!-- B. Modelado de Procesos -->
      <section>
        <div class="flex items-center gap-6 mb-16 text-[#ea4335]">
           <div class="w-16 h-16 bg-[#fce8e6] rounded-2xl md:rounded-3xl flex items-center justify-center font-black text-2xl shadow-xl shadow-red-100 -rotate-3">B</div>
           <div>
             <h2 class="text-2xl md:text-3xl font-black text-[#202124] m-0">Modelado de Procesos</h2>
             <p class="text-sm text-[#5f6368] mt-1 font-medium italic">Diagrama de Flujo de Datos (DFD)</p>
           </div>
        </div>

        <div class="grid lg:grid-cols-2 gap-12 md:gap-16 items-start">
           <div class="space-y-8">
               <p class="text-base md:text-lg text-[#5f6368] font-light leading-relaxed">
                 Mediante el **Diagrama de Flujo de Datos (DFD)**, mapeamos cómo los datos se transforman desde una simple coordenada GPS hasta una instrucción de navegación clara para el usuario.
               </p>
               
               <MotionStagger client:load className="space-y-4">
                  {[
                    { title: 'Nivel 0: Contexto', desc: 'Vista macro de la interacción entre el Estudiante y el ecosistema U-Locate.' },
                    { title: 'Nivel 1: Procesamiento', desc: 'Desglose de la lógica de búsqueda, filtrado y validación de destinos.' },
                    { title: 'Nivel 2: Detalle Operativo', desc: 'Nivel de zoom máximo: algoritmos de minimización de rutas y persistencia.' }
                  ].map((level, i) => (
                    <MotionStaggerItem client:load>
                       <div class="flex gap-6 p-5 md:p-6 items-center bg-white border border-[#dadce0] rounded-xl md:rounded-2xl hover:border-red-400 group transition-all">
                          <span class="text-xl md:text-2xl font-black text-red-100 group-hover:text-red-500 transition-all font-mono">0{i}</span>
                          <div>
                            <h4 class="text-[11px] md:text-sm font-black text-[#202124] uppercase tracking-wider mb-1">{level.title}</h4>
                            <p class="text-[11px] md:text-xs text-[#5f6368] leading-tight font-medium">{level.desc}</p>
                          </div>
                       </div>
                    </MotionStaggerItem>
                  ))}
               </MotionStagger>
           </div>
           
           <div class="bg-[#202124] p-8 md:p-12 rounded-[2rem] md:rounded-[2.5rem] shadow-2xl relative overflow-hidden group">
              <div class="absolute -top-10 -right-10 w-40 h-40 bg-red-400 opacity-5 blur-3xl group-hover:opacity-10 transition-all"></div>
              <h3 class="text-xl font-bold text-white mb-8 border-b border-white/10 pb-6">Explosión de Proceso</h3>
              <p class="text-sm text-white/50 mb-10 leading-relaxed font-light">
                Documentamos la transformación de la señal. El sistema toma datos crudos y devuelve valor informativo.
              </p>
              <div class="space-y-4 text-[10px] uppercase font-black tracking-widest text-[#eee]">
                <div class="flex justify-between items-center py-2 border-b border-white/5 group/line">
                   <span class="group-hover/line:text-red-400 transition-colors">Input: Localización Actual</span>
                   <span class="text-red-400 animate-pulse">→</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-white/5 group/line">
                   <span class="group-hover/line:text-red-400 transition-colors">Proc: Motor de Búsqueda</span>
                   <span class="text-red-400 animate-pulse">→</span>
                </div>
                <div class="flex justify-between items-center py-2 group/line">
                   <span class="group-hover/line:text-red-400 transition-colors">Output: Mapa Dinámico</span>
                   <span class="text-red-400">OK</span>
                </div>
              </div>
           </div>
        </div>
      </section>

      <!-- C. Modelado de Redes -->
      <section>
        <div class="flex items-center gap-6 mb-16 text-[#34a853]">
           <div class="w-16 h-16 bg-[#e6f4ea] rounded-2xl md:rounded-3xl flex items-center justify-center font-black text-2xl shadow-xl shadow-green-100 rotate-2">C</div>
           <div>
             <h2 class="text-2xl md:text-3xl font-black text-[#202124] m-0">Arquitectura de Red</h2>
             <p class="text-sm text-[#5f6368] mt-1 uppercase tracking-widest font-black opacity-30">Topología de Conexión</p>
           </div>
        </div>

        <div class="bg-white border-2 border-dashed border-[#dadce0] rounded-[2rem] md:rounded-[3.5rem] p-6 md:p-16 flex flex-col lg:flex-row gap-12 md:gap-16 items-center">
           <div class="grow space-y-8 w-full">
              <h4 class="text-xl md:text-2xl font-black text-[#202124] leading-tight text-center md:text-left">Infraestructura Distribuida</h4>
              <p class="text-base md:text-lg text-[#5f6368] font-light leading-relaxed text-center md:text-left">
                Para garantizar latencia cero en el campus, separamos la carga en tres nodos de ejecución físicos y lógicos.
              </p>
              <ul class="space-y-4">
                {[
                  { label: 'CLIENTE', detail: 'App React que renderiza capas de Mapbox y gestiona el estado local del usuario.', color: '#4285f4' },
                  { label: 'SERVIDOR', detail: 'Middleware en Node.js que orquesta las API y aplica reglas de negocio.', color: '#ea4335' },
                  { label: 'DATOS', detail: 'Base de datos PostGIS optimizada para consultas de proximidad geográfica.', color: '#34a853' }
                ].map(item => (
                  <li class="flex items-start gap-4 p-4 rounded-xl hover:bg-slate-50 transition-colors border border-transparent hover:border-slate-200">
                    <span class="w-1.5 h-10 rounded-full shrink-0" style={`background-color: ${item.color}`}></span>
                    <div>
                      <strong class="text-[#202124] text-xs md:text-sm block mb-1">[{item.label}]</strong>
                      <p class="text-[11px] md:text-xs text-[#5f6368] font-medium leading-relaxed">{item.detail}</p>
                    </div>
                  </li>
                ))}
              </ul>
           </div>
           
           <div class="w-full lg:w-1/3 p-10 md:p-12 bg-[#f8f9fa] border border-[#dadce0] rounded-3xl shadow-lg flex flex-col gap-6 scale-[0.95] md:scale-100">
              <div class="p-6 bg-white border-2 border-blue-100 rounded-2xl text-center text-[10px] font-extrabold uppercase text-blue-600 shadow-sm relative">
                <span class="absolute -top-1.5 -left-1.5 w-3 h-3 bg-blue-500 rounded-full animate-ping opacity-20"></span>
                Web/Mobile Front
              </div>
              <div class="flex justify-center py-1"><span class="text-slate-200 text-xs">↕</span></div>
              <div class="p-6 bg-[#202124] rounded-2xl text-center text-[10px] font-extrabold uppercase text-white shadow-xl">App Server Node.js</div>
              <div class="flex justify-center py-1"><span class="text-slate-200 text-xs">↕</span></div>
              <div class="p-6 bg-white border-2 border-green-100 rounded-2xl text-center text-[10px] font-extrabold uppercase text-green-600 shadow-sm font-mono tracking-tighter">PostGIS Spatial Engine</div>
           </div>
        </div>
      </section>
    </div>
  </article>
</MainLayout>
