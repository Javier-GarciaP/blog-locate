---
import MainLayout from "../layouts/MainLayout.astro";
import {
  MotionFadeIn,
  MotionStagger,
  MotionStaggerItem,
} from "../components/MotionFadeIn.tsx";
---

<MainLayout title="Estrategia RAD | U-Locate">
  <article class="section-container prose-google max-w-5xl">
    <MotionFadeIn client:load direction="down" className="mb-20 text-center md:text-left">
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-[#e6f4ea] rounded-full mb-6 text-[#34a853]">
        <span class="w-1.5 h-1.5 bg-[#34a853] rounded-full animate-pulse"></span>
        <span class="text-[10px] font-black uppercase tracking-widest">Fase 4: Metodología Ágil</span>
      </div>
      <h1 class="text-5xl md:text-6xl font-black text-[#202124] tracking-tight mb-8">
        Estrategia de Desarrollo RAD
      </h1>
      <p class="text-xl text-[#5f6368] font-light leading-relaxed max-w-3xl mx-auto md:mx-0">
        No esperamos el sistema perfecto; lo iteramos. Aplicamos el Desarrollo Rápido de Aplicaciones (RAD) para transformar el campus en ciclos de alto impacto.
      </p>
    </MotionFadeIn>

    <div class="space-y-32">
      <!-- Iteration Grid -->
      <section>
        <h2 class="text-3xl font-black mb-20 text-center text-[#202124] tracking-tight flex items-center justify-center gap-6">
           <span class="w-12 h-px bg-[#dadce0]"></span>
           Evolución del Producto
           <span class="w-12 h-px bg-[#dadce0]"></span>
        </h2>
        <div class="relative">
          <!-- Central Line -->
          <div class="absolute left-1/2 -underline -translate-x-1/2 w-px h-full bg-gradient-to-b from-[#dadce0] via-[#dadce0] to-transparent hidden md:block"></div>

          <MotionStagger client:load className="flex flex-col gap-24 relative">
            <!-- Iteration 1 -->
            <MotionStaggerItem client:load className="flex flex-col md:flex-row gap-16 items-center">
              <div class="flex-1 text-right order-2 md:order-1">
                 <div class="inline-block px-4 py-1 bg-red-100 text-red-600 rounded-full text-[10px] font-black uppercase mb-4 tracking-widest shadow-sm">Iteración 01</div>
                 <h3 class="text-3xl font-black text-[#202124] mb-4">Baja Fidelidad</h3>
                 <p class="text-lg text-[#5f6368] font-light leading-relaxed">
                   Wireframes base y validación de la estructura del DER. Diseñamos la lógica de navegación por categorías para usuarios UNET.
                 </p>
              </div>
              <div class="w-20 h-20 rounded-[2rem] bg-white border-2 border-red-200 shadow-2xl flex items-center justify-center font-black text-2xl z-20 order-1 md:order-2 text-red-500 scale-110 mb-8 md:mb-0 transition-transform hover:rotate-6">1</div>
              <div class="flex-1 order-3">
                 <div class="card-google p-10 bg-[#fce8e6]/10 border-[#fbd5d1] rounded-[2.5rem] relative group">
                    <div class="absolute top-6 left-6 text-2xl opacity-20 filter grayscale-0">🖋️</div>
                    <h4 class="text-xs font-black uppercase text-[#ea4335] mb-4 tracking-widest opacity-60">Entregable Técnico</h4>
                    <p class="text-sm font-medium text-[#202124]">
                      Diagrama Entidad-Relación normalizado + Prototipo de flujo de navegación en baja fidelidad.
                    </p>
                 </div>
              </div>
            </MotionStaggerItem>

            <!-- Iteration 2 -->
            <MotionStaggerItem client:load className="flex flex-col md:flex-row gap-16 items-center">
              <div class="flex-1 order-2 md:order-2">
                 <div class="inline-block px-4 py-1 bg-yellow-100 text-yellow-600 rounded-full text-[10px] font-black uppercase mb-4 tracking-widest shadow-sm">Iteración 02</div>
                 <h3 class="text-3xl font-black text-[#202124] mb-4">Prototipo Funcional</h3>
                 <p class="text-lg text-[#5f6368] font-light leading-relaxed pr-12">
                   Conectamos la lógica al motor de búsqueda. Implementamos el buscador de salones con una base de datos real en tiempo real.
                 </p>
              </div>
              <div class="w-20 h-20 rounded-[2rem] bg-white border-2 border-yellow-200 shadow-2xl flex items-center justify-center font-black text-2xl z-20 order-1 md:order-1 md:ml-auto text-yellow-500 scale-110 mb-8 md:mb-0 transition-transform hover:-rotate-6">2</div>
              <div class="flex-1 order-3 md:text-right">
                 <div class="card-google p-10 bg-[#fef7e0]/30 border-[#feefc3] inline-block text-left rounded-[2.5rem] relative group">
                    <div class="absolute top-6 right-6 text-2xl opacity-20 filter grayscale-0">⚙️</div>
                    <h4 class="text-xs font-black uppercase text-[#fbbc04] mb-4 tracking-widest opacity-60">Entregable Beta</h4>
                    <p class="text-sm font-medium text-[#202124]">
                      Aplicación Funcional con búsqueda en tiempo real + Motor de rutas básico integrado.
                    </p>
                 </div>
              </div>
            </MotionStaggerItem>

            <!-- Iteration 3 -->
            <MotionStaggerItem client:load className="flex flex-col md:flex-row gap-16 items-center">
              <div class="flex-1 text-right order-2 md:order-1">
                 <div class="inline-block px-4 py-1 bg-blue-100 text-blue-600 rounded-full text-[10px] font-black uppercase mb-4 tracking-widest shadow-sm">Iteración 03</div>
                 <h3 class="text-3xl font-black text-[#202124] mb-4">Pulido e Ingeniería</h3>
                 <p class="text-lg text-[#5f6368] font-light leading-relaxed">
                   Integración de Framer Motion, diseño minimalista Google Developers y optimización del grafo de navegación final.
                 </p>
              </div>
              <div class="w-20 h-20 rounded-[2rem] bg-white border-2 border-blue-200 shadow-2xl flex items-center justify-center font-black text-2xl z-20 order-1 md:order-2 text-blue-500 scale-110 mb-8 md:mb-0 transition-transform hover:rotate-12">3</div>
              <div class="flex-1 order-3">
                 <div class="card-google p-10 bg-[#e8f0fe] border-[#d2e3fc] rounded-[2.5rem] relative group">
                    <div class="absolute top-6 left-6 text-2xl opacity-20 filter grayscale-0">🚀</div>
                    <h4 class="text-xs font-black uppercase text-[#1a73e8] mb-4 tracking-widest opacity-60">Sistema de Producción</h4>
                    <p class="text-sm font-medium text-[#202124]">
                      Blog de Ingeniería Completo + Documentación de Arquitectura + Sistema U-Locate Final.
                    </p>
                 </div>
              </div>
            </MotionStaggerItem>
          </MotionStagger>
        </div>
      </section>

      <!-- Final Quote Card -->
      <section class="max-w-4xl mx-auto pt-24 pb-32">
        <div class="bg-[#202124] rounded-[3.5rem] p-16 md:p-24 text-center items-center shadow-2xl relative group overflow-hidden">
           <div class="absolute inset-0 bg-green-500 opacity-0 group-hover:opacity-5 blur-3xl transition-all"></div>
           <h3 class="text-4xl font-black text-white mb-10 tracking-tight leading-tight">Proyecto Final UNET Listo</h3>
           <p class="text-xl text-white/50 mb-16 leading-relaxed font-light italic max-w-2xl mx-auto">
             "U-Locate no solo resuelve una necesidad logística, sino que sienta las bases para un campus hiper-conectado, donde la información fluye al ritmo de sus estudiantes."
           </p>
           <div class="flex flex-col md:flex-row justify-center gap-6 relative z-10">
              <a href="/" class="btn-google bg-[#1a73e8] text-white border-transparent px-10 py-4 font-black rounded-2xl hover:bg-blue-600 transition-all text-sm uppercase tracking-wide">
                Volver al Inicio
              </a>
           </div>
        </div>
      </section>
    </div>
  </article>
</MainLayout>
