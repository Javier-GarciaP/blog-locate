---
import MainLayout from "../layouts/MainLayout.astro";
import {
  MotionFadeIn,
  MotionStagger,
  MotionStaggerItem,
} from "../components/MotionFadeIn.tsx";
---

<MainLayout title="Estrategia RAD | U-Locate">
  <article class="section-container prose-google max-w-5xl">
    <MotionFadeIn client:load direction="down" className="mb-20 text-center md:text-left">
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-[#e6f4ea] rounded-full mb-6 text-[#34a853]">
        <span class="w-1.5 h-1.5 bg-[#34a853] rounded-full animate-pulse"></span>
        <span class="text-[10px] font-black uppercase tracking-widest">Fase 4: Metodología Ágil</span>
      </div>
      <h1 class="text-4xl md:text-7xl font-black text-[#202124] tracking-tight mb-8">
        Estrategia <span class="text-[#34a853]">RAD</span>
      </h1>
      <p class="text-lg md:text-xl text-[#5f6368] font-light leading-relaxed max-w-3xl">
        Para no perdernos en la teoría eterna, aplicamos el <strong>Desarrollo Rápido de Aplicaciones</strong>. Construimos, probamos y refinamos en ciclos de alta velocidad.
      </p>
    </MotionFadeIn>

    <div class="space-y-32">
      <!-- Iteration Grid -->
      <section>
        <div class="relative">
          <!-- Central Line -->
          <div class="absolute left-1/2 -underline -translate-x-1/2 w-px h-full bg-[#dadce0] hidden md:block opacity-30"></div>

          <MotionStagger client:load className="flex flex-col gap-24 relative">
            <!-- Iteration 1 -->
            <MotionStaggerItem client:load className="flex flex-col md:flex-row gap-8 md:gap-16 items-center">
              <div class="flex-1 text-center md:text-right order-2 md:order-1 w-full">
                 <div class="inline-block px-4 py-1 bg-red-100 text-red-600 rounded-full text-[10px] font-black uppercase mb-4 tracking-widest">Iteración 01</div>
                 <h3 class="text-2xl md:text-3xl font-black text-[#202124] mb-4">Modelado y Maquetas</h3>
                 <p class="text-base md:text-lg text-[#5f6368] font-light leading-relaxed">
                   En este primer ciclo definimos el <strong>modelado básico</strong> y creamos prototipos de baja fidelidad. Diseñamos las maquetas de las pantallas principales para validar la navegación con el equipo.
                 </p>
              </div>
              <div class="w-16 h-16 md:w-20 md:h-20 rounded-full bg-white border-2 border-red-200 shadow-xl flex items-center justify-center font-black text-xl md:text-2xl z-20 order-1 md:order-2 text-red-500">1</div>
              <div class="flex-1 order-3 w-full">
                 <div class="p-8 bg-[#f8f9fa] border border-[#dadce0] rounded-[2rem] shadow-sm">
                    <h4 class="text-[10px] font-black uppercase text-[#5f6368] mb-4 tracking-widest opacity-40">Entregable</h4>
                    <p class="text-sm font-bold text-[#202124]">
                      Diagramas Conceptuales + Wireframes de Baja Fidelidad.
                    </p>
                 </div>
              </div>
            </MotionStaggerItem>

            <!-- Iteration 2 -->
            <MotionStaggerItem client:load className="flex flex-col md:flex-row gap-16 items-center">
              <div class="flex-1 order-2 md:order-2">
                 <div class="inline-block px-4 py-1 bg-yellow-100 text-yellow-600 rounded-full text-[10px] font-black uppercase mb-4 tracking-widest">Iteración 02</div>
                 <h3 class="text-2xl md:text-3xl font-black text-[#202124] mb-4">Prototipo Funcional</h3>
                 <p class="text-base md:text-lg text-[#5f6368] font-light leading-relaxed">
                   Refinamos el modelo técnico y avanzamos hacia el <strong>prototipo funcional</strong>. Aquí es donde el código se encuentra con los diagramas, permitiendo la búsqueda real de edificios.
                 </p>
              </div>
              <div class="w-16 h-16 md:w-20 md:h-20 rounded-full bg-white border-2 border-yellow-200 shadow-xl flex items-center justify-center font-black text-xl md:text-2xl z-20 order-1 md:order-1 md:ml-auto text-yellow-500">2</div>
              <div class="flex-1 order-3 md:text-right">
                 <div class="p-8 bg-[#f8f9fa] border border-[#dadce0] rounded-[2rem] shadow-sm">
                    <h4 class="text-[10px] font-black uppercase text-[#5f6368] mb-4 tracking-widest opacity-40">Entregable</h4>
                    <p class="text-sm font-bold text-[#202124]">
                      MVP (Producto Mínimo Viable) con lógica de búsqueda activa.
                    </p>
                 </div>
              </div>
            </MotionStaggerItem>

            <!-- Iteration 3 -->
            <MotionStaggerItem client:load className="flex flex-col md:flex-row gap-16 items-center">
              <div class="flex-1 text-right order-2 md:order-1">
                 <div class="inline-block px-4 py-1 bg-blue-100 text-blue-600 rounded-full text-[10px] font-black uppercase mb-4 tracking-widest">Iteración 03</div>
                 <h3 class="text-2xl md:text-3xl font-black text-[#202124] mb-4">Ingeniería Completa</h3>
                 <p class="text-base md:text-lg text-[#5f6368] font-light leading-relaxed">
                   Fase final de <strong>Ingeniería de Información</strong>. Pulimos cada animación, optimizamos el motor de rutas y consolidamos el sistema final en producción.
                 </p>
              </div>
              <div class="w-16 h-16 md:w-20 md:h-20 rounded-full bg-white border-2 border-blue-200 shadow-xl flex items-center justify-center font-black text-xl md:text-2xl z-20 order-1 md:order-2 text-blue-500">3</div>
              <div class="flex-1 order-3">
                 <div class="p-8 bg-[#202124] text-white rounded-[2rem] shadow-2xl overflow-hidden relative group">
                    <div class="absolute inset-0 bg-[#1a73e8] opacity-0 group-hover:opacity-10 transition-all"></div>
                    <h4 class="text-[10px] font-black uppercase text-white/40 mb-4 tracking-widest">Final System</h4>
                    <p class="text-sm font-bold">
                      U-Locate 1.0 listo para el despliegue y uso estudiantil.
                    </p>
                 </div>
              </div>
            </MotionStaggerItem>
          </MotionStagger>
        </div>
      </section>

      <!-- Final Quote Card -->
      <section class="max-w-4xl mx-auto pt-12 md:pt-24 pb-20 md:pb-32 px-6">
        <div class="bg-[#202124] rounded-[2rem] md:rounded-[3.5rem] p-10 md:p-24 text-center items-center shadow-2xl relative group overflow-hidden">
           <div class="absolute inset-0 bg-green-500 opacity-0 group-hover:opacity-5 blur-3xl transition-all"></div>
           <h3 class="text-3xl md:text-4xl font-black text-white mb-8 md:mb-10 tracking-tight leading-tight">Proyecto Final UNET Listo</h3>
           <p class="text-base md:text-xl text-white/50 mb-12 md:mb-16 leading-relaxed font-light italic max-w-2xl mx-auto px-4">
             "U-Locate no solo resuelve una necesidad logística, sino que sienta las bases para un campus hiper-conectado, donde la información fluye al ritmo de sus estudiantes."
           </p>
           <div class="flex flex-col md:flex-row justify-center gap-6 relative z-10">
              <a href="/" class="btn-google bg-[#1a73e8] text-white border-transparent px-8 md:px-10 py-4 font-black rounded-2xl hover:bg-blue-600 transition-all text-sm uppercase tracking-wide">
                Volver al Inicio
              </a>
           </div>
        </div>
      </section>
    </div>
  </article>
</MainLayout>
