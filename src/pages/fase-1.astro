---
import MainLayout from '../layouts/MainLayout.astro';
import { MotionFadeIn, MotionStagger, MotionStaggerItem } from '../components/MotionFadeIn.tsx';

const investigationHechos = [
  { 
    title: 'Entrevistas y Cuestionarios', 
    desc: 'Aplicamos herramientas directas a estudiantes y personal administrativo para recolectar datos reales sin suposiciones.', 
    icon: '🗣️',
    color: '#4285f4' 
  },
  { 
    title: 'Observación Directa', 
    desc: 'Recorrimos el campus documentando puntos críticos de desorientación y flujo de personas en tiempo real.', 
    icon: '👁️',
    color: '#34a853' 
  },
  { 
    title: 'Análisis de Documentación', 
    desc: 'Estudiamos los planos físicos actuales para contrastarlos con la realidad del terreno.', 
    icon: '📋',
    color: '#ea4335' 
  }
];

const dcaSteps = [
  { id: '01', title: 'Liderazgo y Pautas', detail: 'Santiago Hernandez como líder estableció la hoja de ruta y los estándares técnicos del proyecto.' },
  { id: '02', title: 'Asignación de Roles', detail: 'Cada integrante recibió responsabilidades claras (Analista, DBA, UX) para evitar solapamientos.' },
  { id: '03', title: 'Definición de Requisitos', detail: 'Consolidación de las necesidades reales del usuario en un informe técnico de requerimientos.' }
];
---

<MainLayout title="Fase 1: Investigación | Jose Garcia Blog">
  <article class="section-container prose-google max-w-5xl">
    <MotionFadeIn client:load direction="down" className="mb-12 md:mb-20 text-center md:text-left">
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-[#e8f0fe] rounded-full mb-6 text-[#1a73e8]">
        <span class="w-1.5 h-1.5 bg-[#1a73e8] rounded-full animate-pulse"></span>
        <span class="text-[10px] font-black uppercase tracking-widest">Fase 1: Investigación de Hechos</span>
      </div>
      <h1 class="text-4xl md:text-7xl font-black text-[#202124] tracking-tight mb-8 leading-tight">
        Primero el Hecho, <span class="text-[#1a73e8]">Luego el Código</span>
      </h1>
      <p class="text-lg md:text-xl text-[#5f6368] font-light leading-relaxed max-w-3xl">
        Antes de trazar una sola línea de código, debemos entender el problema a profundidad. No suponemos; investigamos la realidad de la UNET.
      </p>
    </MotionFadeIn>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-16 mb-20 md:mb-32">
      <!-- Left Column: DCA -->
      <div class="lg:col-span-2 order-2 lg:order-1">
        <section class="mb-20">
          <div class="flex items-center gap-6 mb-12">
            <div class="w-16 h-16 bg-[#e8f0fe] rounded-3xl flex items-center justify-center text-[#1a73e8] font-black text-2xl shadow-xl shadow-blue-100 rotate-3">DCA</div>
            <div>
              <h2 class="text-3xl font-black text-[#202124] m-0">Desarrollo Conjunto</h2>
              <p class="text-sm text-[#5f6368] mt-1 font-medium">Liderazgo y Asignación de Responsabilidades</p>
            </div>
          </div>
          
          <p class="text-lg mb-12 text-[#5f6368] font-light leading-relaxed">
            Aplicar el **DCA** significa que el líder establece las pautas desde el día uno. Santiago Hernandez asignó a cada integrante una responsabilidad específica, permitiendo que la definición de requisitos fuera un proceso de ingeniería coordinado y no un caos creativo.
          </p>
          
          <div class="space-y-4">
            {dcaSteps.map(step => (
              <div class="flex gap-6 p-6 md:p-8 bg-[#f8f9fa] border border-[#dadce0] rounded-[2rem] group hover:bg-white hover:shadow-xl transition-all duration-300">
                <span class="text-3xl font-black text-[#dadce0] group-hover:text-[#1a73e8] transition-colors">{step.id}</span>
                <div>
                  <h4 class="font-bold text-[#202124] mb-2">{step.title}</h4>
                  <p class="text-sm text-[#5f6368] leading-relaxed font-medium">{step.detail}</p>
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- Investigation Section -->
        <section>
          <h2 class="text-2xl md:text-3xl font-black mb-12 text-[#202124] text-center md:text-left">Investigación de Hechos</h2>
          <p class="text-base text-[#5f6368] mb-12 font-light leading-relaxed italic">
            "La investigación de hechos es el pilar que sostiene todo sistema. Utilizamos entrevistas personalizadas, cuestionarios masivos y la observación directa en el terreno."
          </p>
          <MotionStagger client:load className="grid grid-cols-1 sm:grid-cols-3 gap-6">
            {investigationHechos.map(item => (
              <MotionStaggerItem client:load>
                <div class="card-google p-8 h-full flex flex-col items-center text-center group hover:-translate-y-2 transition-all border-[#dadce0]">
                  <div class="text-4xl mb-6 group-hover:scale-125 transition-transform">{item.icon}</div>
                  <h4 class="font-black text-[11px] text-[#202124] uppercase tracking-wider mb-4" style={`color: ${item.color}`}>{item.title}</h4>
                  <p class="text-[12px] text-[#5f6368] leading-relaxed font-medium">
                    {item.desc}
                  </p>
                </div>
              </MotionStaggerItem>
            ))}
          </MotionStagger>
        </section>
      </div>

      <!-- Sidebar: Requirements -->
      <aside class="lg:col-span-1 order-1 lg:order-2">
        <div class="sticky top-28 space-y-8">
          <div class="bg-[#202124] text-white rounded-[2.5rem] p-10 shadow-2xl relative overflow-hidden group">
            <div class="absolute -top-10 -right-10 w-32 h-32 bg-white/5 rounded-full blur-2xl group-hover:bg-white/10 transition-all"></div>
            
            <h3 class="text-xl font-black mb-8 border-b border-white/10 pb-6">Informe de Requerimientos</h3>
            <div class="space-y-8">
              <div class="border-l-2 border-[#1a73e8] pl-6 py-1">
                <p class="text-[10px] font-black text-[#4285f4] uppercase tracking-widest mb-2">Entregable Final</p>
                <h4 class="text-sm font-bold leading-tight">Mapa de Hechos Reales</h4>
                <p class="text-xs text-white/40 mt-2 font-medium">Consolidación de entrevistas y datos brutos en necesidades técnicas.</p>
              </div>
              <div class="border-l-2 border-[#dadce0] pl-6 py-1 opacity-50">
                <p class="text-[10px] font-black text-white/40 uppercase tracking-widest mb-2">Objetivo</p>
                <h4 class="text-sm font-bold">Cero Suposiciones</h4>
                <p class="text-xs text-white/40 mt-2 font-medium">Validación de cada campo de datos con el usuario final.</p>
              </div>
            </div>
          </div>
          
          <div class="bg-[#f8f9fa] border border-[#dadce0] rounded-3xl p-8 text-center">
             <div class="w-12 h-12 bg-white border border-[#dadce0] rounded-full flex items-center justify-center mx-auto mb-6 shadow-sm">💡</div>
             <p class="text-xs font-bold text-[#5f6368] italic leading-relaxed">
               "El éxito de un sistema de información reside en la veracidad técnica de su entrada inicial."
             </p>
          </div>
        </div>
      </aside>
    </div>
  </article>
</MainLayout>
