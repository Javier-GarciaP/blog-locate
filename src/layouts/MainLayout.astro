---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Blog de ingeniería del proyecto U-Locate." } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
  { name: 'Descripción', path: '/' },
  { name: 'Investigación', path: '/fase-1' },
  { name: 'Arquitectura', path: '/fase-2' },
  { name: 'Diccionario', path: '/fase-3' },
  { name: 'RAD', path: '/fase-4' },
];
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
		<title>{title} | Jose Garcia Blog</title>
	</head>
	<body class="flex flex-col min-h-screen">
		<nav class="border-b border-[#dadce0] bg-white sticky top-0 z-50">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="flex justify-between h-16 items-center">
					<div class="flex items-center gap-8">
						<a href="/" class="flex items-center gap-2">
							<span class="text-[#202124] font-bold text-lg md:text-xl whitespace-nowrap tracking-tight italic">Jose</span>
							<span class="text-[#1a73e8] font-black text-lg md:text-xl tracking-tighter">Garcia.</span>
						</a>
						<div class="hidden md:flex items-center gap-1">
							{navItems.map(item => (
								<a 
									href={item.path} 
									class={`px-4 py-2 rounded-md text-sm font-medium transition-colors ${currentPath === item.path ? 'bg-[#e8f0fe] text-[#1a73e8]' : 'text-[#5f6368] hover:bg-[#f1f3f4]'}`}
								>
									{item.name}
								</a>
							))}
						</div>
					</div>
					<div class="flex items-center gap-4">
						<button id="mobile-menu-button" class="md:hidden p-2 rounded-full hover:bg-[#f1f3f4] transition-colors" aria-label="Menu principal">
              <svg id="menu-icon" class="w-6 h-6 text-[#5f6368]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path></svg>
              <svg id="close-icon" class="hidden w-6 h-6 text-[#5f6368]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
					</div>
				</div>
			</div>

      <!-- Mobile Menu -->
      <div id="mobile-menu" class="hidden md:hidden border-b border-[#dadce0] bg-white overflow-hidden transition-all duration-300">
        <div class="px-4 pt-2 pb-6 space-y-1">
          {navItems.map(item => (
            <a 
              href={item.path} 
              class={`block px-4 py-3 rounded-xl text-base font-medium ${currentPath === item.path ? 'bg-[#e8f0fe] text-[#1a73e8]' : 'text-[#5f6368] hover:bg-[#f8f9fa]'}`}
            >
              {item.name}
            </a>
          ))}
        </div>
      </div>
		</nav>
		
		<main class="grow">
			<slot />
		</main>

		<footer class="bg-[#f8f9fa] border-t border-[#dadce0] py-16">
			<div class="max-w-7xl mx-auto px-6 sm:px-8">
				<div class="grid grid-cols-1 md:grid-cols-4 gap-12 sm:gap-8">
					<div class="col-span-1 md:col-span-2">
            <h3 class="text-[#202124] font-bold mb-4 text-lg italic tracking-tight">Jose Garcia <span class="text-[#1a73e8] not-italic font-black">.</span></h3>
            <p class="text-[#5f6368] text-sm leading-relaxed max-w-sm">
              Espacio personal donde documento mi trayectoria en Ingeniería de Sistemas, enfocado en el desarrollo de U-Locate para la UNET.
            </p>
          </div>
          <div>
            <h4 class="text-[#202124] font-bold mb-6 text-xs uppercase tracking-widest opacity-60">Etapas del Proyecto</h4>
            <ul class="space-y-4 text-sm font-medium text-[#5f6368]">
              <li><a href="/fase-1" class="hover:text-[#1a73e8] transition-colors">Investigación de Hechos</a></li>
              <li><a href="/fase-2" class="hover:text-[#1a73e8] transition-colors">Arquitectura de Datos</a></li>
              <li><a href="/fase-3" class="hover:text-[#1a73e8] transition-colors">Diccionario Técnico</a></li>
              <li><a href="/fase-4" class="hover:text-[#1a73e8] transition-colors">Estrategia RAD</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-[#202124] font-bold mb-6 text-xs uppercase tracking-widest opacity-60">Colaboradores</h4>
            <div class="space-y-4">
              <div>
                <p class="text-[10px] font-black text-blue-500 uppercase tracking-tighter">Líder Proyecto</p>
                <p class="text-xs font-bold text-[#202124]">Santiago Hernandez</p>
              </div>
              <div>
                <p class="text-[10px] font-black text-red-500 uppercase tracking-tighter">Coordinación</p>
                <p class="text-xs font-bold text-[#202124]">Ana Andrade</p>
              </div>
            </div>
          </div>
				</div>
				<div class="mt-20 pt-8 border-t border-[#dadce0] flex flex-col md:flex-row justify-between items-center gap-8">
					<p class="text-[10px] font-bold text-[#5f6368] uppercase tracking-widest">&copy; 2026 Jose Garcia — Portafolio Multimedia & SI.</p>
          <div class="flex gap-4">
            <span class="w-2 h-2 bg-[#4285f4] rounded-full"></span>
            <span class="w-2 h-2 bg-[#ea4335] rounded-full"></span>
            <span class="w-2 h-2 bg-[#fbbc05] rounded-full"></span>
            <span class="w-2 h-2 bg-[#34a853] rounded-full"></span>
          </div>
				</div>
			</div>
		</footer>

    <script>
      const menuButton = document.getElementById('mobile-menu-button');
      const mobileMenu = document.getElementById('mobile-menu');
      const menuIcon = document.getElementById('menu-icon');
      const closeIcon = document.getElementById('close-icon');

      menuButton?.addEventListener('click', () => {
        const isHidden = mobileMenu?.classList.contains('hidden');
        if (isHidden) {
          mobileMenu?.classList.remove('hidden');
          menuIcon?.classList.add('hidden');
          closeIcon?.classList.remove('hidden');
        } else {
          mobileMenu?.classList.add('hidden');
          menuIcon?.classList.remove('hidden');
          closeIcon?.classList.add('hidden');
        }
      });
    </script>
	</body>
</html>
